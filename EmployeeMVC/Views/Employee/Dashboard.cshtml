@model EmployeeMVC.Models.DashboardViewModel

@{
    ViewBag.Title = "Dashboard";
}

<style>

.hero {

    background: white;

    border-radius: 24px;

    padding: 40px;

    margin-bottom: 30px;

    box-shadow: 0 10px 30px rgba(0,0,0,.05);

}

.hero h1 {

    font-size: 42px;

    color: #0B1220;

    margin-bottom: 10px;

}

.hero p {

    color: #64748B;

    font-size: 18px;

}

.cards {

    display: flex;

    gap: 20px;

    margin-bottom: 30px;

}

.card {

    flex: 1;

    background: white;

    border-radius: 20px;

    padding: 25px;

    box-shadow: 0 10px 25px rgba(0,0,0,.05);

    transition: all .3s ease;

}

.card:hover {

    transform: translateY(-5px);

    box-shadow: 0 20px 35px rgba(0,0,0,.08);

}

.number {

    font-size: 34px;

    font-weight: 700;

    color: #06B6D4;

}

.label {

    color: #64748B;

    margin-top: 10px;

}

.activity {

    background: white;

    border-radius: 20px;

    padding: 25px;

    box-shadow: 0 10px 25px rgba(0,0,0,.05);

}

.activity h3 {

    margin-bottom: 15px;

    color: #0B1220;

}

.activity-item {

    padding: 12px 0;

    border-bottom: 1px solid #F1F5F9;

}

</style>

<div class="hero">

    <h1>Good Morning, Vallabh 👋</h1>

    <p>
        Manage your workforce efficiently and monitor employee operations.
    </p>

</div>

<div class="cards">

    <div class="card">

        <div class="number">@Model.TotalEmployees</div>

        <div class="label">Employees</div>

    </div>

    <div class="card">

        <div class="number">@Model.TotalCities</div>

        <div class="label">Cities</div>

    </div>

    <div class="card">

        <div class="number">@DateTime.Now.Year</div>

        <div class="label">Current Year</div>

    </div>

</div>

<div class="activity">

    <h3>Recent Activity</h3>

    <div class="activity-item">
        Employee records updated successfully.
    </div>

    <div class="activity-item">
        Dashboard accessed by vallabh.
    </div>

    <div class="activity-item">
        Employee management system operational.
    </div>

</div>