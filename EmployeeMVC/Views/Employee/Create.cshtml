@model EmployeeMVC.Models.Employee

@{
    ViewBag.Title = "Add Employee";
}

<style>

    .form-card {
        max-width: 700px;
        background: white;
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
    }

    .page-title {
        font-size: 32px;
        font-weight: 700;
        color: #0B1220;
        margin-bottom: 10px;
    }

    .page-subtitle {
        color: #64748B;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #374151;
        font-weight: 600;
    }

    .form-control {
        width: 100%;
        padding: 14px;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        font-size: 15px;
    }

        .form-control:focus {
            outline: none;
            border-color: #06B6D4;
        }

    .btn-save {
        background: #06B6D4;
        color: white;
        border: none;
        padding: 14px 25px;
        border-radius: 12px;
        cursor: pointer;
        font-size: 15px;
        transition: .3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
        }
</style>

<div class="form-card">

    <div class="page-title">
        Add Employee
    </div>

    <div class="page-subtitle">
        Create a new employee record.
    </div>

    @Html.ValidationSummary(true, "", new { @style = "color:red;" })

    @using (Html.BeginForm())
    {

        <div class="form-group">
            <label>First Name</label>

            @Html.TextBoxFor(
                m => m.FirstName,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.FirstName,
                "",
                new { @style = "color:red;" })
        </div>

        <div class="form-group">
            <label>Last Name</label>

            @Html.TextBoxFor(
                m => m.LastName,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.LastName,
                "",
                new { @style = "color:red;" })
        </div>

        <div class="form-group">

            <label>Gender</label>

            @Html.DropDownListFor(
                m => m.Gender,
                new List<SelectListItem>
                {
                    new SelectListItem { Text = "Male", Value = "Male" },
                    new SelectListItem { Text = "Female", Value = "Female" }
                },
                "-- Select Gender --",
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.Gender,
                "",
                new { @style = "color:red;" })

        </div>

        <div class="form-group">

            <label>Designation</label>

            @Html.TextBoxFor(
                m => m.Designation,
                new { @class = "form-control" })

            @Html.ValidationMessageFor(
                m => m.Designation,
                "",
                new { @style = "color:red;" })

        </div>

        <div class="form-group">

            <label>Salary</label>

            @Html.TextBoxFor(
                m => m.Salary,
                new
                {
                    @class = "form-control",
                    type = "number",
                    min = "1"
                })

            @Html.ValidationMessageFor(
                m => m.Salary,
                "",
                new { @style = "color:red;" })

        </div>

        <div class="form-group">

    <label>City</label>

    @Html.TextBoxFor(
        m => m.City,
        new { @class = "form-control" })

    @Html.ValidationMessageFor(
        m => m.City,
        "",
        new { @style = "color:red;" })

</div>

         <div class="form-group">

             <label>Birth Date</label>

             @Html.TextBoxFor(
                 m => m.BirthDate,
                 "{0:yyyy-MM-dd}",
                 new
                 {
                     @class = "form-control",
                     type = "date"
                 })

             @Html.ValidationMessageFor(
                 m => m.BirthDate,
                 "",
                 new { @style = "color:red;" })

         </div>

        <button type="submit"
                class="btn-save">

            Save Employee

        </button>
    }
</div>
    

   