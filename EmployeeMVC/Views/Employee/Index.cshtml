@model List<EmployeeMVC.Models.Employee>

@{
    ViewBag.Title = "Employees";
}

<style>

    body {
        background: transparent;
    }

    .hero-section {
        margin-bottom: 20px;
    }

        .hero-section h1 {
            color: #0F172A;
            font-size: 36px;
            margin-bottom: 10px;
        }

        .hero-section p {
            color: #64748B;
            font-size: 16px;
        }

    .employee-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(380px,1fr));
        gap: 18px;
    }

    .employee-card {
        background: white;
        border-radius: 24px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
        transition: .3s;
    }

        .employee-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,.08);
        }

    .avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #06B6D4;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .emp-name {
        font-size: 22px;
        font-weight: 700;
        color: #0F172A;
    }

    .emp-city {
        color: #64748B;
        margin-top: 8px;
    }

    .emp-date {
        color: #64748B;
        margin-top: 8px;
        margin-bottom: 20px;
    }

    .card-actions {
        display: flex;
        gap: 10px;
    }


    .add-btn {
        background: #06B6D4;
        color: white;
        text-decoration: none;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 600;
        transition: .3s;
    }

        .add-btn:hover {
            transform: translateY(-2px);
            opacity: .9;
        }

    .edit-btn {
        background: #14B8A6;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
        margin-right: 5px;
    }

    .delete-btn {
        background: #EF4444;
        color: white;
        padding: 8px 15px;
        border-radius: 8px;
        text-decoration: none;
    }

        .edit-btn:hover,
        .delete-btn:hover {
            opacity: .85;
            transition: .3s;
        }

    table tbody tr:hover {
        background: #F8FAFC;
        transition: .2s;
    }


</style>

<div class="hero-section">

    <h1>Employee Directory</h1>

    <p>
        Manage employee records and workforce data.
    </p>

</div>

@if (TempData["Success"] != null)
{
    <div style="
        background:#DCFCE7;
        color:#166534;
        padding:15px 20px;
        border-radius:12px;
        margin-bottom:25px;
        font-weight:600;">

        ✓ @TempData["Success"]

    </div>
}

<div style="display:flex; justify-content:flex-start; gap:15px; align-items:center; margin-bottom:15px;">

    @using (Html.BeginForm("Index", "Employee", FormMethod.Get))
    {
        <div style="display:flex; gap:10px; flex-wrap:wrap;">

            <input type="text"
                   name="search"
                   value="@(Request["search"])"
                   placeholder="Search employee..."
                   style=" width: 280px; padding: 14px; border: 1px solid #CBD5E1; border-radius: 12px; background: white; box-shadow: 0 5px 20px rgba(0,0,0,.05);" />

            <select name="gender"
                    style=" padding: 14px; border: 1px solid #CBD5E1; border-radius: 12px; background: white; box-shadow: 0 5px 20px rgba(0,0,0,.05);">

                <option value="">All Genders</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>

            </select>

            <select name="designation"
                    style=" padding: 14px; border: 1px solid #CBD5E1; border-radius: 12px; background: white; box-shadow: 0 5px 20px rgba(0,0,0,.05);">

                <option value="">All Designations</option>
                <option value="Software Engineer">Software Engineer</option>
                <option value="Senior Software Engineer">Senior Software Engineer</option>
                <option value="Project Manager">Project Manager</option>
                <option value="UI/UX Designer">UI/UX Designer</option>
                <option value="HR Executive">HR Executive</option>
                <option value="Data Analyst">Data Analyst</option>
                <option value="QA Engineer">QA Engineer</option>

            </select>

            <button type="submit" class="add-btn">
                🔍 Search
            </button>

        </div>
    }

<div style="display:flex; gap:10px;">

    <a href="/Employee/Create"
       class="add-btn">

        + Add Employee

    </a>

    <a href="/Employee/ExportEmployees"
       class="add-btn">

        ⬇ Export Excel

    </a>

    <a href="/Employee/DownloadTemplate"
       class="add-btn">

        📄 Template

    </a>

    <a href="#"
       onclick="document.getElementById('importModal').style.display='block'; return false;"
       class="add-btn">

        ⬆ Import Excel

    </a>

</div>

</div>

<div style="
    background:white;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 10px 30px rgba(0,0,0,.05);">

    <div style="
        padding:20px;
        border-bottom:1px solid #E2E8F0;
        font-weight:700;
        color:#0F172A;">

        Total Employees: @Model.Count

    </div>

    <table style="
        width:100%;
        border-collapse:collapse;">

        <thead>

            <tr style="
                background:#0F172A;
                color:white;">

                <th style="padding:16px;text-align:left;">Emp ID</th>
                <th style="padding:16px;text-align:left;">Employee Name</th>
                <th style="padding:16px;text-align:left;">Designation</th>
                <th style="padding:16px;text-align:left;">Salary</th>
                <th style="padding:16px;text-align:left;">City</th>
                <th style="padding:16px;text-align:left;">D.O.B</th>
                <th style="padding:16px;text-align:center;">Actions</th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Count == 0)
            {
                <tr>

                    <td colspan="7"
                        style="
                padding:50px;
                text-align:center;">

                        <div style="
                     font-size:48px;
                     margin-bottom:15px;">

                            🔍

                        </div>

                        <div style="
                     font-size:22px;
                     font-weight:700;
                     color:#0F172A;
                     margin-bottom:8px;">

                            No Employees Found

                        </div>

                        <div style="
                     color:#64748B;">

                            Try a different search or clear filters.

                        </div>

                    </td>

                </tr>
            }
            else
            {
                foreach (var emp in Model)
                {
                    <tr style="
                border-bottom:1px solid #E2E8F0;">

                        <td style="
                    padding:14px;
                    font-weight:700;
                    color:#06B6D4;">

                            EMP-@emp.EmployeeCode.ToString("D3")

                        </td>

                        <td style="padding:14px;font-weight:600;">
                            @emp.FirstName @emp.LastName
                        </td>

                        <td style="padding:14px;">

                            <span style="
                        background:#E0F2FE;
                        color:#0369A1;
                        padding:6px 12px;
                        border-radius:999px;
                        font-size:12px;
                        font-weight:600;">

                                @emp.Designation

                            </span>

                        </td>

                        <td style="
                    padding:14px;
                    color:#14B8A6;
                    font-weight:700;">

                            ₹@emp.Salary.ToString("N0")

                        </td>

                        <td style="padding:14px;">
                            @emp.City
                        </td>

                        <td style="padding:14px;">
                            @emp.BirthDate.ToString("dd-MM-yyyy")
                        </td>

                        <td style="padding:14px;text-align:center;">

                            <a href="/Employee/ViewEmployee/@emp.EmployeeCode"
                               title="View"
                               style="text-decoration:none;font-size:18px;margin-right:14px;">
                                🔎
                            </a>

                            <a href="/Employee/Edit/@emp.EmployeeCode"
                               title="Edit"
                               style="text-decoration:none;font-size:18px;margin-right:14px;">
                                📝
                            </a>

                            <a href="#"
                               title="Delete"
                               onclick="openDeleteModal(@emp.EmployeeCode,'@emp.FirstName @emp.LastName'); return false;"
                               style="text-decoration:none;font-size:18px;">
                                ❌
                            </a>

                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>

<div id="importModal"
     style="
     display:none;
     position:fixed;
     inset:0;
     background:rgba(15,23,42,.45);
     z-index:9999;">

    <div style="
         background:white;
         width:500px;
         padding:35px;
         border-radius:24px;
         box-shadow:0 20px 50px rgba(0,0,0,.15);
         position:absolute;
         top:50%;
         left:50%;
         transform:translate(-50%,-50%);">

        <h2 style="
            margin-top:0;
            color:#0F172A;">

            Import Employees

        </h2>

        <p style="
           color:#64748B;
           margin-bottom:20px;">

            Upload an Excel (.xlsx) file created using the template.

        </p>

        @using (Html.BeginForm(
            "ImportEmployees",
            "Employee",
            FormMethod.Post,
            new { enctype = "multipart/form-data" }))
        {
            <input type="file"
                   name="file"
                   accept=".xlsx"
                   style="
                   width:100%;
                   padding:12px;
                   border:1px solid #CBD5E1;
                   border-radius:12px;" />

            <div style="
                 display:flex;
                 justify-content:flex-end;
                 gap:10px;
                 margin-top:25px;">

                <button type="button"
                        onclick="document.getElementById('importModal').style.display='none';"
                        style="
                        border:none;
                        background:#06B6D4;
                        color:white;
                        padding:12px 18px;
                        border-radius:12px;
                        cursor:pointer;">

                    Cancel

                </button>

                <button type="submit"
                        style="
                        border:none;
                        background:#14B8A6;
                        color:white;
                        padding:12px 18px;
                        border-radius:12px;
                        cursor:pointer;">

                    Import Employees

                </button>

            </div>
        }

    </div>

</div>

<div id="deleteModal"
     style="
     display:none;
     position:fixed;
     inset:0;
     background:rgba(15,23,42,.45);
     z-index:9999;">

    <div style="
         background:white;
         width:450px;
         padding:35px;
         border-radius:24px;
         box-shadow:0 20px 50px rgba(0,0,0,.15);
         position:absolute;
         top:50%;
         left:50%;
         transform:translate(-50%,-50%);">

        <h2 style="
            margin-top:0;
            color:#0F172A;">

            Delete Employee

        </h2>

        <p style="
           color:#64748B;
           margin-bottom:10px;">

            This action cannot be undone.

        </p>

        <div style="
             background:#F8FAFC;
             padding:15px;
             border-radius:12px;
             margin-top:15px;
             margin-bottom:25px;">

            <strong id="deleteEmployeeName"></strong>

        </div>

        <div style="
             display:flex;
             justify-content:flex-end;
             gap:10px;">

            <button onclick="closeDeleteModal()"
                    style="
                    border:none;
                    background:#06B6D4;
                    color:white;
                    padding:12px 18px;
                    border-radius:12px;
                    cursor:pointer;">

                Cancel

            </button>

            <a id="deleteLink"
               href="#"
               style="
               background:#EF4444;
               color:white;
               text-decoration:none;
               padding:12px 18px;
               border-radius:12px;">

                Delete Employee

            </a>

        </div>

    </div>

</div>

<script>

    function openDeleteModal(id, name) {
        document.getElementById("deleteModal").style.display = "block";

        document.getElementById("deleteEmployeeName").innerHTML =
            name;

        document.getElementById("deleteLink").href =
            "/Employee/Delete/" + id;
    }

    function closeDeleteModal() {
        document.getElementById("deleteModal").style.display = "none";
    }

</script>



